# Core app secrets
JWT_SECRET=replace-with-a-long-random-production-secret
JWT_EXPIRATION_MS=36000000

# Internal service auth
PRODUCT_INTERNAL_TOKEN=replace-with-an-internal-service-jwt
STRIPE_SECRET_KEY=

# Databases
POSTGRES_USER=user
POSTGRES_PASSWORD=replace-with-a-production-db-password

# RabbitMQ
RABBITMQ_VHOST=/
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=replace-with-a-production-rabbitmq-password

# Keep traces enabled for the order timeline
OTEL_JAVA_TOOL_OPTIONS=-javaagent:/otel/opentelemetry-javaagent.jar
OTEL_TRACES_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
TEMPO_BASE_URL=http://tempo:3200
